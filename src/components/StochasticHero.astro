---
/**
 * Full-bleed stochastic process hero.
 * Client island: run-and-tumble rods with Gillespie-like state-switching and trail fade.
 */
import { site } from '../data/site';
---

<section class="stochastic-hero" aria-label="Introduction">
  <canvas class="stochastic-hero__canvas" data-stochastic-canvas aria-hidden="true"></canvas>
  <div class="stochastic-hero__veil" aria-hidden="true"></div>
  <div class="stochastic-hero__content">
    <p class="stochastic-hero__brand">{site.title}</p>
    <h1 class="stochastic-hero__headline">{site.headline}</h1>
    <p class="stochastic-hero__support">
      Infection outcomes depend on stochastic processes that population averages obscure. I recover
      those dynamics from single-cell and spatial transcriptomes in SIV and tuberculosis.
    </p>
    <div class="btn-row">
      <a class="btn" href="/research/">View research</a>
      <a class="btn btn-ghost" href="/cv/">CV</a>
    </div>
  </div>
</section>

<script>
  type Agent = {
    x: number;
    y: number;
    theta: number; // heading (radians)
    speed: number;
    length: number; // major-axis half-extent proxy for draw scale
    width: number;
    state: 0 | 1; // 0 susceptible-like, 1 activated/infected-like
    trail: { x: number; y: number }[];
  };

  function initStochasticCanvas(canvas: HTMLCanvasElement) {
    const ctx = canvas.getContext('2d', { alpha: true });
    if (!ctx) return;

    const reduced =
      window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isMobile = window.matchMedia('(max-width: 768px)').matches;

    let width = 0;
    let height = 0;
    let dpr = 1;
    let agents: Agent[] = [];
    let raf = 0;
    let running = false;
    let mouse = { x: -9999, y: -9999, active: false };

    const COUNT = isMobile ? 48 : 90;
    const TRAIL = isMobile ? 14 : 26;
    const SWITCH_RATE = 0.004; // per-frame state flip probability (Gillespie-ish)
    const TUMBLE_RATE = 0.018; // per-frame tumble probability
    const ROT_DIFFUSION = 0.035; // small heading noise during runs
    const BASE_SPEED = isMobile ? 0.72 : 0.82;
    const SPEED_JITTER = 0.18;
    const MOUSE_TURN = 0.08; // heading bias toward pointer
    const ACCENT = { r: 61, g: 207, b: 182 };
    const MUTED = { r: 107, g: 122, b: 114 };

    function resize() {
      const rect = canvas.getBoundingClientRect();
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      width = rect.width;
      height = rect.height;
      canvas.width = Math.floor(width * dpr);
      canvas.height = Math.floor(height * dpr);
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function spawn(): Agent {
      const state: 0 | 1 = Math.random() < 0.18 ? 1 : 0;
      return {
        x: Math.random() * width,
        y: Math.random() * height,
        theta: Math.random() * Math.PI * 2,
        speed: BASE_SPEED + (Math.random() - 0.5) * SPEED_JITTER,
        length: state === 1 ? 7.5 : 5.2,
        width: state === 1 ? 2.2 : 1.5,
        state,
        trail: [],
      };
    }

    function seed() {
      agents = Array.from({ length: COUNT }, spawn);
    }

    function syncBodyFromState(a: Agent) {
      a.length = a.state === 1 ? 7.5 : 5.2;
      a.width = a.state === 1 ? 2.2 : 1.5;
    }

    function step() {
      for (const a of agents) {
        // Run: small rotational diffusion for zest without sideways slides
        a.theta += (Math.random() - 0.5) * 2 * ROT_DIFFUSION;

        // Occasional tumble: large random reorient
        if (Math.random() < TUMBLE_RATE) {
          a.theta += (Math.random() - 0.5) * Math.PI * 1.6;
        }

        // Soft mouse heading bias (turn-to-mouse, not free velocity shove)
        if (mouse.active) {
          const desired = Math.atan2(mouse.y - a.y, mouse.x - a.x);
          let dTheta = desired - a.theta;
          while (dTheta > Math.PI) dTheta -= Math.PI * 2;
          while (dTheta < -Math.PI) dTheta += Math.PI * 2;
          a.theta += dTheta * MOUSE_TURN;
        }

        // Velocity along major axis
        const vx = a.speed * Math.cos(a.theta);
        const vy = a.speed * Math.sin(a.theta);
        a.x += vx;
        a.y += vy;

        // Wrap
        if (a.x < 0) a.x += width;
        if (a.x > width) a.x -= width;
        if (a.y < 0) a.y += height;
        if (a.y > height) a.y -= height;

        // Stochastic state switch
        if (Math.random() < SWITCH_RATE) {
          a.state = a.state === 0 ? 1 : 0;
          syncBodyFromState(a);
        }

        a.trail.push({ x: a.x, y: a.y });
        if (a.trail.length > TRAIL) a.trail.shift();
      }
    }

    function drawCapsule(a: Agent, alpha: number) {
      const c = a.state === 1 ? ACCENT : MUTED;
      const len = a.length;
      const w = a.width;
      ctx!.save();
      ctx!.translate(a.x, a.y);
      ctx!.rotate(a.theta);
      ctx!.beginPath();
      if (typeof ctx!.roundRect === 'function') {
        ctx!.roundRect(-len / 2, -w / 2, len, w, w / 2);
      } else {
        // Stadium fallback: rect + end caps
        const halfL = len / 2 - w / 2;
        ctx!.moveTo(-halfL, -w / 2);
        ctx!.lineTo(halfL, -w / 2);
        ctx!.arc(halfL, 0, w / 2, -Math.PI / 2, Math.PI / 2);
        ctx!.lineTo(-halfL, w / 2);
        ctx!.arc(-halfL, 0, w / 2, Math.PI / 2, -Math.PI / 2);
        ctx!.closePath();
      }
      ctx!.fillStyle = `rgba(${c.r},${c.g},${c.b},${alpha})`;
      ctx!.fill();
      ctx!.restore();
    }

    function draw() {
      // Trail fade via translucent clear
      ctx!.fillStyle = 'rgba(10, 14, 18, 0.16)';
      ctx!.fillRect(0, 0, width, height);

      for (const a of agents) {
        const c = a.state === 1 ? ACCENT : MUTED;
        if (a.trail.length > 1) {
          ctx!.beginPath();
          ctx!.moveTo(a.trail[0].x, a.trail[0].y);
          for (let i = 1; i < a.trail.length; i++) {
            ctx!.lineTo(a.trail[i].x, a.trail[i].y);
          }
          ctx!.strokeStyle = `rgba(${c.r},${c.g},${c.b},${a.state === 1 ? 0.5 : 0.25})`;
          ctx!.lineWidth = a.width;
          ctx!.lineCap = 'round';
          ctx!.lineJoin = 'round';
          ctx!.stroke();
        }
        drawCapsule(a, a.state === 1 ? 0.92 : 0.55);
      }
    }

    function drawStill() {
      ctx!.fillStyle = '#0a0e12';
      ctx!.fillRect(0, 0, width, height);
      // Advance trails once then freeze
      for (let i = 0; i < TRAIL; i++) step();
      // Opaque redraw without fade
      ctx!.fillStyle = '#0a0e12';
      ctx!.fillRect(0, 0, width, height);
      for (const a of agents) {
        const c = a.state === 1 ? ACCENT : MUTED;
        if (a.trail.length > 1) {
          ctx!.beginPath();
          ctx!.moveTo(a.trail[0].x, a.trail[0].y);
          for (let i = 1; i < a.trail.length; i++) {
            ctx!.lineTo(a.trail[i].x, a.trail[i].y);
          }
          ctx!.strokeStyle = `rgba(${c.r},${c.g},${c.b},${a.state === 1 ? 0.55 : 0.28})`;
          ctx!.lineWidth = a.width;
          ctx!.lineCap = 'round';
          ctx!.lineJoin = 'round';
          ctx!.stroke();
        }
        drawCapsule(a, 0.78);
      }
    }

    function loop() {
      if (!running) return;
      step();
      draw();
      raf = requestAnimationFrame(loop);
    }

    function start() {
      if (running || reduced) return;
      running = true;
      raf = requestAnimationFrame(loop);
    }

    function stop() {
      running = false;
      cancelAnimationFrame(raf);
    }

    resize();
    seed();

    if (reduced) {
      drawStill();
    } else {
      ctx!.fillStyle = '#0a0e12';
      ctx!.fillRect(0, 0, width, height);
      start();
    }

    const io = new IntersectionObserver(
      ([entry]) => {
        if (reduced) return;
        if (entry.isIntersecting) start();
        else stop();
      },
      { threshold: 0.05 },
    );
    io.observe(canvas);

    const onResize = () => {
      resize();
      seed();
      if (reduced) drawStill();
    };
    window.addEventListener('resize', onResize);

    const onMove = (e: PointerEvent) => {
      const rect = canvas.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
      mouse.active = true;
    };
    const onLeave = () => {
      mouse.active = false;
    };
    canvas.addEventListener('pointermove', onMove);
    canvas.addEventListener('pointerleave', onLeave);

    return () => {
      stop();
      io.disconnect();
      window.removeEventListener('resize', onResize);
      canvas.removeEventListener('pointermove', onMove);
      canvas.removeEventListener('pointerleave', onLeave);
    };
  }

  function boot() {
    const canvas = document.querySelector<HTMLCanvasElement>(
      '[data-stochastic-canvas]',
    );
    if (canvas) initStochasticCanvas(canvas);
  }

  boot();
  document.addEventListener('astro:page-load', boot);
</script>

<style>
  .stochastic-hero {
    position: relative;
    min-height: calc(100vh - var(--header-h));
    min-height: calc(100dvh - var(--header-h));
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: var(--ink);
  }

  .stochastic-hero__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    cursor: crosshair;
  }

  .stochastic-hero__veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10, 14, 18, 0.15) 0%,
      rgba(10, 14, 18, 0.35) 45%,
      rgba(10, 14, 18, 0.92) 100%
    );
    pointer-events: none;
  }

  .stochastic-hero__content {
    position: relative;
    z-index: 2;
    width: min(100% - 2rem, var(--page-max));
    margin-inline: auto;
    padding: 0 0 clamp(2.5rem, 8vh, 5rem);
    max-width: 40rem;
    margin-left: max(1rem, calc((100% - var(--page-max)) / 2));
  }

  .stochastic-hero__brand {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 500;
    margin: 0 0 0.75rem;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .stochastic-hero__headline {
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 3vw, 1.85rem);
    font-weight: 400;
    margin: 0 0 0.85rem;
    color: var(--accent);
    line-height: 1.25;
  }

  .stochastic-hero__support {
    margin: 0;
    color: var(--text-muted);
    font-size: 1.05rem;
    max-width: 34rem;
    line-height: 1.55;
  }

  @media (max-width: 640px) {
    .stochastic-hero__content {
      margin-left: 1rem;
      margin-right: 1rem;
      width: auto;
    }
  }
</style>
