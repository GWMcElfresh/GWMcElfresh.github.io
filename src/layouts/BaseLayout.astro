---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
}

const {
  title,
  description = site.description,
  bodyClass = '',
} = Astro.props;

const pageTitle = title ? `${title} · ${site.title}` : `${site.title} · ${site.tagline}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content={site.title} />
    <link rel="canonical" href={new URL(Astro.url.pathname, site.url).href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={`${site.title} Blog`} href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={new URL(Astro.url.pathname, site.url).href} />
  </head>
  <body class={bodyClass}>
    <div class="site-shell">
      <SiteHeader />
      <main class="site-main">
        <slot />
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
